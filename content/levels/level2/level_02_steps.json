{
  "level": "02",
  "title": "Set Up Base",
  "steps": [
    {
      "id": "step-01",
      "short_title": "Open Explore GPTs",
      "description": "Click Explore GPTs in the left sidebar of ChatGPT.",
      "type": "action"
    },
    {
      "id": "step-02",
      "short_title": "Click Create",
      "description": "Click the Create button in the top right corner of the Explore GPTs page.",
      "type": "action"
    },
    {
      "id": "step-03",
      "short_title": "Switch to Configure",
      "description": "Click the Configure tab at the top of the GPT builder.",
      "type": "action"
    },
    {
      "id": "step-04",
      "short_title": "Add Name",
      "description": "Copy and paste the GPT name into the Name field.",
      "type": "copy",
      "resource_id": "gpt-name"
    },
    {
      "id": "step-05",
      "short_title": "Add Description",
      "description": "Copy and paste the GPT description into the Description field.",
      "type": "copy",
      "resource_id": "gpt-description"
    },
    {
      "id": "step-06",
      "short_title": "Add Instructions",
      "description": "Copy the full GPT instructions and paste into the Instructions field.",
      "type": "copy",
      "resource_id": "gpt-instructions"
    },
    {
      "id": "step-07",
      "short_title": "Hit Create",
      "description": "Click the Create button in the top right corner to save your GPT.",
      "type": "action"
    },
    {
      "id": "step-08",
      "short_title": "Upload Mission Data",
      "description": "Open your new GPT and upload the mission data file.",
      "type": "download",
      "resource_id": "mission-data"
    },
    {
      "id": "step-09",
      "short_title": "Ask 5 Questions",
      "description": "Run each of the 5 mission questions and save your answers.",
      "type": "mission",
      "resource_id": "mission-questions"
    },
    {
      "id": "step-10",
      "short_title": "Invent Your Tool",
      "description": "Ask your GPT to invent one special tool for the mission.",
      "type": "prompt",
      "resource_id": "prompt-special-tool"
    },
    {
      "id": "step-11",
      "short_title": "Generate Debrief",
      "description": "Ask your GPT to compile everything into a mission debrief txt file.",
      "type": "prompt",
      "resource_id": "prompt-create-txt"
    }
  ]
}
